# ===================
# 服务器配置
# ===================
PORT=8000

# ===================
# API 配置
# ===================
# API 端点地址
API_ENDPOINT=https://chat.z.ai/api/v2/chat/completions

# 认证令牌（支持多个，逗号分隔）
# 客户端请求时需要在 Authorization header 中携带
AUTH_TOKEN=sk-your-token-here

# Z.AI JWT Token（支持多个，逗号分隔）
# 从 chat.z.ai 浏览器 DevTools > Application > Local Storage 获取
BACKUP_TOKEN=

# Captcha Provider 地址
# 用于自动获取阿里云验证码 token，不配置则不注入 captcha_verify_param
CAPTCHA_PROVIDER_URL=http://127.0.0.1:9876

# ===================
# 功能配置
# ===================
# 调试日志
DEBUG_LOGGING=false

# 工具调用支持（通过 prompt injection 模拟，效果取决于模型）
TOOL_SUPPORT=true

# 请求失败时的重试次数（不含首次请求）
RETRY_COUNT=5

# 跳过认证令牌验证
SKIP_AUTH_TOKEN=false

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===================
# 显示配置
# ===================
# 备注信息，在 / 端点显示
# 支持 | 或 \n 作为换行符
NOTE=
