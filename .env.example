# ===================
# 服务器配置
# ===================
PORT=8000

# ===================
# API 配置
# ===================
# API 端点地址
API_ENDPOINT=https://chat.z.ai/api/v2/chat/completions

# 可选：把上游请求转发到 Windows 真实浏览器 companion，由浏览器页面内 fetch 发出请求
# BROWSER_BRIDGE_URL=http://127.0.0.1:8787
# BROWSER_BRIDGE_SECRET=change-me

# 认证令牌（支持多个，逗号分隔）
# 用于验证客户端请求
AUTH_TOKEN=sk-your-token-here

# 备用令牌（支持多个，逗号分隔）
# 用于多模态请求
BACKUP_TOKEN=

# ===================
# 功能配置
# ===================
# 调试日志
DEBUG_LOGGING=false

# 工具调用支持
TOOL_SUPPORT=true

# 请求失败时的重试次数（不含首次请求）
RETRY_COUNT=5

# 跳过认证令牌验证
SKIP_AUTH_TOKEN=false

# 扫描限制（字符数）
SCAN_LIMIT=200000

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===================
# 显示配置
# ===================
# 多行备注，在 / 端点显示
# 支持 | 或 \n 作为换行符
# 示例: NOTE=第一行|第二行|第三行
NOTE=
