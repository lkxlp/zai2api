[Unit]
Description=zai-captcha-provider
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/zai-captcha-provider
ExecStart=/usr/bin/node /opt/zai-captcha-provider/server.js
Restart=always
RestartSec=10
Environment=HOST=0.0.0.0
Environment=PORT=9876
Environment=POOL_SIZE=5
Environment=TOKEN_TTL=240000
Environment=CHROMIUM_PATH=/usr/bin/chromium
MemoryMax=2G

[Install]
WantedBy=multi-user.target
